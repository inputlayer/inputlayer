# ── Required ─────────────────────────────────────────────────────────────

# Domain for TLS certificate (Caddy auto-provisions via Let's Encrypt)
DOMAIN=demo.inputlayer.ai

# Admin password for the InputLayer instance
# The demo gateway uses this to create viewer accounts
INPUTLAYER_ADMIN_PASSWORD=

# ── Optional ─────────────────────────────────────────────────────────────

# Bootstrap API key (auto-generated if not set)
INPUTLAYER_BOOTSTRAP_API_KEY=

# Log level: trace | debug | info | warn | error
INPUTLAYER_LOG_LEVEL=info

# Default knowledge graph for demo access requests
DEMO_DEFAULT_KG=default

# How long invite links stay valid (hours, default 7 days)
DEMO_INVITE_EXPIRY_HOURS=168

# ── Email (SMTP) ────────────────────────────────────────────────────────
# Set SMTP_TRANSPORT=console to log emails to stdout instead of sending

SMTP_TRANSPORT=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=InputLayer Demo <demo@inputlayer.ai>

# ── Advanced ─────────────────────────────────────────────────────────────

# Override ports if 80/443 are taken
# HTTP_PORT=80
# HTTPS_PORT=443
