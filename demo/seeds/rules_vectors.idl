// ── Rules + Vector Search Demo ──────────────────────────────────────────
// Multi-hop reasoning combined with vector similarity ranking.
// Demonstrates: rules deriving eligibility, then vectors ranking products.

// ── Printer ink compatibility scenario ─────────────────────────────────
// A customer asks "what compatible ink can I buy?"
// Step 1: Check account standing (multi-hop reasoning)
// Step 2: Derive eligibility
// Step 3: Rank by vector similarity

// Customers and their invoices
+customer[("cust_1", "Acme Corp"),
          ("cust_2", "Globex Inc"),
          ("cust_3", "Initech LLC")]

+paid_invoice[("cust_1", "inv_99"),
              ("cust_1", "inv_100"),
              ("cust_2", "inv_50")]

+dispute_resolved[("cust_1", "d_42"),
                  ("cust_2", "d_10")]

// Products with embedding vectors for similarity search
// Embeddings represent ink characteristics (density, viscosity, color profile)
+product[("pg245",   "Canon PG-245",       [0.82, 0.44, 0.91]),
         ("cl246",   "Canon CL-246",       [0.79, 0.41, 0.88]),
         ("pg245xl", "Canon PG-245XL",     [0.84, 0.46, 0.93]),
         ("ep202",   "Epson 202",          [0.31, 0.85, 0.22]),
         ("br3013",  "Brother LC3013",     [0.28, 0.79, 0.19]),
         ("hp61",    "HP 61",             [0.35, 0.82, 0.25])]

// Compatibility rules: which products work with which printers
+compatible_with[("pg245",   "canon_pixma_mg2525"),
                 ("cl246",   "canon_pixma_mg2525"),
                 ("pg245xl", "canon_pixma_mg2525"),
                 ("pg245",   "canon_pixma_ts3120"),
                 ("cl246",   "canon_pixma_ts3120")]

+owns_printer[("cust_1", "canon_pixma_mg2525"),
              ("cust_2", "canon_pixma_ts3120"),
              ("cust_3", "canon_pixma_mg2525")]

// ── Rules (multi-hop reasoning) ────────────────────────────────────────

// Hop 1: account in good standing if paid AND disputes resolved
+good_standing(C) <- paid_invoice(C, _), dispute_resolved(C, _)

// Hop 2: eligible to buy if in good standing
+eligible(C, P) <- good_standing(C), product(P, _, _)

// Hop 3: can actually purchase if eligible AND product is compatible with their printer
+can_purchase(C, Pid, Name) <-
  eligible(C, Pid),
  product(Pid, Name, _),
  owns_printer(C, Printer),
  compatible_with(Pid, Printer)

// ── Try these queries ──────────────────────────────────────────────────
//
// Who is in good standing?
// ?good_standing(C)
//
// What can cust_1 purchase?
// ?can_purchase("cust_1", Pid, Name)
//
// Rules + vector ranking in one query:
// ?eligible("cust_1", Pid), product(Pid, Name, Emb), Dist = cosine(Emb, [0.80, 0.43, 0.90]), Dist < 0.2
//
// Why is cust_3 NOT eligible?
// .why_not eligible("cust_3", "pg245")
