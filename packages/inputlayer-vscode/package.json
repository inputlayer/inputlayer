{
  "name": "inputlayer-iql",
  "displayName": "InputLayer IQL",
  "description": "Syntax highlighting for InputLayer (.iql) files",
  "version": "0.1.0",
  "publisher": "inputlayer",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "inputlayer-iql",
        "aliases": [
          "InputLayer",
          "IQL"
        ],
        "extensions": [
          ".iql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "inputlayer-iql",
        "scopeName": "source.iql",
        "path": "./syntaxes/iql.tmLanguage.json"
      }
    ]
  },
  "configurationDefaults": {
    "[inputlayer-iql]": {
      "editor.fontLigatures": "'calt', 'liga'",
      "editor.bracketPairColorization.enabled": true
    }
  }
}
